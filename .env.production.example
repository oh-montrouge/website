# Application
GO_ENV=production
PORT=3000
DATABASE_URL=postgres://ohm:CHANGE_ME@postgres:5432/ohm_production?sslmode=disable
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# Domain — used by Caddy for automatic HTTPS via Let's Encrypt
APP_DOMAIN=your.domain.example.com

# Docker image to pull on deploy
APP_IMAGE=ghcr.io/your-org/ohm-webapp:latest

# PostgreSQL service — user/password must match DATABASE_URL above
POSTGRES_USER=ohm
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ohm_production
